{
    "name": "itinerisltd/kirki-disable-pagebuilder",
    "description": "Disables Kirki v6 page builder features, keeping only the Customizer field framework",
    "license": "MIT",
    "type": "wordpress-muplugin",
    "authors": [
        {
            "name": "Itineris Limited",
            "email": "dev@itineris.co.uk",
            "homepage": "https://itineris.co.uk/",
            "role": "Company"
        },
        {
            "name": "Lee Hanbury-Pickett",
            "email": "lee.hanbury@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/itinerisltd/kirki-disable-pagebuilder/",
    "support": {
        "email": "dev@itineris.co.uk",
        "issues": "https://github.com/ItinerisLtd/kirki-disable-pagebuilder/issues",
        "source": "https://github.com/ItinerisLtd/kirki-disable-pagebuilder"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "itinerisltd/itineris-wp-coding-standards": "^1.0",
        "roots/wordpress": "^7.0"
    },
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "roots/wordpress-core-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1.x-dev"
        }
    },
    "scripts": {
        "style:check": "phpcs",
        "style:fix": "phpcbf"
    }
}
